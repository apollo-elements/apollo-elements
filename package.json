{
  "name": "root",
  "private": true,
  "type": "module",
  "logo": {
    "file": "./logo.png"
  },
  "engines": {
    "node": "24.x",
    "npm": ">= 10"
  },
  "scripts": {
    "analyze": "npm run --workspaces --if-present analyze",
    "build": "wireit",
    "build:codegen": "wireit",
    "build:analyze": "wireit",
    "build:compile": "wireit",
    "build:packages": "wireit",
    "clean": "git clean -fX -e node_modules",
    "clean:packages": "node -e \"const g=require('node:fs').globSync('packages/!(create|docs)/**/!(*.config).{js,js.map,d.ts,tgz,tsbuildinfo}');g.forEach(f=>require('node:fs').rmSync(f,{force:true}))\"",
    "clean:create-app": "rm -f packages/create/*.js packages/create/*.js.map packages/create/*.d.ts packages/create/*.tgz",
    "clean:node-modules": "rm -rf packages/*/node_modules",
    "clean:docs": "rm -rf _site docs/_data/customElementsManifests",
    "clean:test": "rm -f test/*.js test/*.d.ts test/*.js.map",
    "release": "sh scripts/release.sh",
    "release:prerelease": "sh scripts/prerelease.sh",
    "postrelease": "npm run clean",
    "docs": "wireit",
    "docs:analyze": "wireit",
    "docs:hugo": "wireit",
    "lint": "wireit",
    "lint:clean": "wireit",
    "lint:eslint": "wireit",
    "lint:types": "wireit",
    "postinstall": "wireit",
    "postinstall:stampino:bundle": "wireit",
    "postinstall:stampino:copy": "wireit",
    "start": "wireit",
    "start:clean": "wireit",
    "start:codegen": "wireit",
    "start:bundle": "wireit",
    "start:tsc": "wireit",
    "start:docs": "wireit",
    "start:docs:hugo": "wireit",
    "test": "wtr",
    "watch:test": "wtr --watch",
    "watch:eslint": "esw",
    "watch:codegen": "graphql-codegen --watch",
    "watch:types": "tsc -b . --watch"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "git add"
    ]
  },
  "workspaces": [
    "./packages/*",
    "./plugins/*",
    "./test",
    "./docs"
  ],
  "devDependencies": {
    "@apollo/client": "^4.0.7",
    "@changesets/cli": "^2.29.7",
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@pwrs/cem": "^0.10.6",
    "@eslint/js": "^9.37.0",
    "@graphql-codegen/cli": "^6.0.0",
    "@graphql-codegen/typed-document-node": "^6.0.1",
    "@graphql-codegen/typescript": "^5.0.1",
    "@graphql-codegen/typescript-operations": "^5.0.1",
    "@graphql-tools/mock": "^9.0.25",
    "@graphql-tools/schema": "^10.0.25",
    "@microsoft/fast-components": "^2.30.6",
    "@open-wc/testing": "^4.0.0",
    "@polymer/polymer": "^3.5.2",
    "@rollup/plugin-commonjs": "^28.0.6",
    "@rollup/plugin-graphql": "^2.0.5",
    "@rollup/plugin-node-resolve": "^16.0.2",
    "@rollup/plugin-typescript": "^12.1.4",
    "@types/chai": "^5.2.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.6.2",
    "@types/tape": "^5.8.1",
    "@types/yargs": "^17.0.33",
    "@typescript-eslint/eslint-plugin": "^8.45.0",
    "@typescript-eslint/parser": "^8.45.0",
    "@web/dev-server-esbuild": "^1.0.4",
    "@web/dev-server-rollup": "^0.6.4",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-commands": "^0.9.0",
    "@web/test-runner-playwright": "^0.11.1",
    "commitizen": "^4.3.1",
    "commitlint-plugin-workspace-scopes": "^1.1.0",
    "esbuild": "^0.25.10",
    "eslint": "^9.37.0",
    "eslint-plugin-easy-loops": "^1.0.1",
    "event-iterator": "^2.0.0",
    "execa": "^9.6.0",
    "graphql": "^16.11.0",
    "graphql-tag": "^2.12.6",
    "hanbi": "^2.0.0",
    "husky": "^9.1.7",
    "hybrids": "^9.1.19",
    "lint-staged": "^16.2.3",
    "lit": "^3.3.1",
    "lit-html": "^3.3.1",
    "mocha": "^11.7.4",
    "rollup": "^4.52.4",
    "rollup-plugin-esbuild": "^6.2.1",
    "tap-difflet": "^0.7.2",
    "tape-es": "^1.2.17",
    "typescript": "^5.9.3",
    "wireit": "^0.14.12"
  },
  "dependencies": {
    "playground-elements": "^0.21.2",
    "tslib": "^2.8.1"
  },
  "wireit": {
    "build": {
      "dependencies": ["build:packages"]
    },
    "build:codegen": {
      "command": "graphql-codegen"
    },
    "build:analyze": {
      "command": "npm run analyze",
      "dependencies": ["build:codegen"]
    },
    "build:compile": {
      "command": "tsc -b .",
      "dependencies": ["build:analyze"]
    },
    "build:packages": {
      "command": "npm run --workspaces --if-present build",
      "dependencies": ["build:compile"]
    },
    "docs": {
      "dependencies": ["docs:hugo"]
    },
    "docs:analyze": {
      "command": "npm run analyze",
      "dependencies": ["build:codegen"]
    },
    "docs:hugo": {
      "command": "cd docs && npm run build",
      "dependencies": ["docs:analyze"]
    },
    "lint": {
      "dependencies": ["lint:types"]
    },
    "lint:clean": {
      "command": "rm -f packages/gluon/declaration.d.ts"
    },
    "lint:eslint": {
      "command": "eslint .",
      "dependencies": ["lint:clean"]
    },
    "lint:types": {
      "command": "tsc -p tsconfig.noEmit.json --tsBuildInfoFile null",
      "dependencies": ["lint:eslint"]
    },
    "postinstall": {
      "dependencies": ["postinstall:stampino:copy"]
    },
    "postinstall:stampino:bundle": {
      "command": "npx esbuild node_modules/stampino/stampino.js --outfile=packages/components/stampino.bundled.js --minify --external:lit-html --bundle --format=esm"
    },
    "postinstall:stampino:copy": {
      "command": "cp node_modules/stampino/stampino.d.ts packages/components/stampino.bundled.d.ts",
      "dependencies": ["postinstall:stampino:bundle"]
    },
    "start": {
      "dependencies": ["start:clean", "start:codegen", "start:bundle", "start:tsc", "start:docs"]
    },
    "start:clean": {
      "command": "npm run clean"
    },
    "start:codegen": {
      "command": "graphql-codegen --watch",
      "service": true
    },
    "start:bundle": {
      "dependencies": ["postinstall:stampino:copy"]
    },
    "start:tsc": {
      "command": "tsc -b . -w",
      "service": true
    },
    "start:docs": {
      "dependencies": ["start:docs:hugo"]
    },
    "start:docs:hugo": {
      "command": "cd docs && npm run serve",
      "service": true,
      "dependencies": ["docs:analyze"]
    }
  }
}
